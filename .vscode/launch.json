{
  "version": "0.2.0",
  "configurations": [
    {
      "command": "npm run dev -- --host 127.0.0.1",
      "name": "Development server",
      "request": "launch",
      "serverReadyAction": {
        "action": "debugWithChrome",
        "killOnServerStop": true,
        "pattern": "Local:\\s+http://127.0.0.1:(\\d+)/",
        "uriFormat": "http://127.0.0.1:%s"
      },
      "type": "node-terminal"
    }
  ]
}
